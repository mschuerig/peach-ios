    "Y1" : {
      "comment" : "The upper bound of the y-axis domain for the progress chart.",
      "isCommentAutoGenerated" : true
    },
    "You'll hear a **reference note**. Your goal is to match its pitch by sliding to the exact same frequency. The closer you get, the better your ear is becoming." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du hörst einen **Referenzton**. Dein Ziel ist es, seine Tonhöhe zu treffen, indem du den Regler auf die gleiche Frequenz schiebst. Je näher du kommst, desto besser wird dein Gehör."
          }
        }
      }
    },
