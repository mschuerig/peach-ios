    "%@ zone: %@ through %@, pitch trend from %@ to %@ %@, %lld data points" : {
      "comment" : "A text summary that describes a section of a training stats view, focusing on a specific time period and the trend in pitch. The first argument is the string “Monthly”, the string “Daily”, the string “Session” or the string “Weekly”. The second argument is the start date of the time period. The third argument is the end date of the time period. The fourth argument is the starting pitch trend. The fifth argument is the ending pitch trend. The sixth argument is the unit of measurement (e.g., \"cents\"). The seventh argument is the number of data points in the time period.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%1$@-Zone: %2$@ bis %3$@, Tonhöhentrend von %4$@ auf %5$@ %6$@, %7$lld Datenpunkte"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@ zone: %2$@ through %3$@, pitch trend from %4$@ to %5$@ %6$@, %7$lld data points"
          }
        }
      }
    },
    "%@ zone: %@, pitch trend %@ %@, %lld data points" : {
      "comment" : "A text summary that describes a single data point in a training zone. The first argument is the string “Monthly”, the string “Daily”, the string “Session” or the string “Weekly”. The second argument is the date of the data point. The third argument is the pitch trend (e.g., \"+0.00\"). The fourth argument is the unit of measurement (e.g., \"cm\"). The fifth argument is the number of data points.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
