#!/bin/bash
# Pre-commit hook: enforce architecture dependency rules.
# 1. archlint — import-based rules (archlint.yaml)
# 2. check-dependencies.sh — type-reference and code-pattern rules
#
# To activate: git config core.hooksPath bin
# (This makes git use bin/ as the hooks directory.)

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

echo "Running architecture checks..."

# archlint: import boundary rules
if command -v archlint &>/dev/null; then
    archlint Peach/
else
    echo "Warning: archlint not installed, skipping import checks"
fi

# Residual rules: cross-feature type refs, print()
"$SCRIPT_DIR/check-dependencies.sh"
